<?xml version="1.0" encoding="utf-8"?>
<!-- Debug: cleartext traffic permitted to ease local development. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
